PORT=8000

# JSearch API (RapidAPI) — get key at rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your-rapidapi-key-here

# Backend API to POST scraped jobs to
BACKEND_URL=http://localhost:5050

# Must match INGEST_SECRET on the backend
INGEST_SECRET=your-internal-scraper-secret

# How often to scrape (minutes) — default 240 = every 4 hours
SCRAPE_INTERVAL_MINUTES=240

# Pages per JSearch query (10 jobs per page). Increase for more jobs per run.
# Free tier: 200 req/month → keep at 1. Paid tiers: set to 3–5.
JSEARCH_PAGES_PER_QUERY=1
