PORT=8000

# Backend API to POST scraped jobs to
BACKEND_URL=http://localhost:5050

# Must match INGEST_SECRET on the backend
INGEST_SECRET=your-internal-scraper-secret

# How often to scrape (minutes)
SCRAPE_INTERVAL_MINUTES=30

# Results fetched per site per search term
SCRAPE_RESULTS_PER_SITE=25

# Optional: comma-separated proxy list e.g. http://user:pass@host:port,…
PROXY_LIST=
