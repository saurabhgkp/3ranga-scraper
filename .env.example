PORT=8000

# JSearch API (RapidAPI) — get key at rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your-rapidapi-key-here

# Backend API to POST scraped jobs to
BACKEND_URL=http://localhost:5050

# Must match INGEST_SECRET on the backend
INGEST_SECRET=your-internal-scraper-secret

# How often to scrape (minutes) — default 240 = every 4 hours
SCRAPE_INTERVAL_MINUTES=240

# Pages per JSearch query (10 jobs per page, max=10 → 100 jobs per call).
# Free tier: 200 req/month → keep at 1. Paid tiers: set to 10.
JSEARCH_PAGES_PER_QUERY=10

# Enable JobSpy web scraping (Indeed / Glassdoor / LinkedIn) for additional volume.
# Free but may get rate-limited. Set to false to disable.
ENABLE_JOBSPY=true

# JobSpy tuning
JOBSPY_RESULTS_PER_SITE=200      # results per site per query
JOBSPY_HOURS_OLD=168             # only fetch jobs posted in last N hours (168 = 7 days)
JOBSPY_TERMS_PER_RUN=35          # jobspy terms scraped per rotation slot (rotates every run)
JOBSPY_LINKEDIN_DESCRIPTIONS=false  # true = full LinkedIn descriptions (very slow)

# Optional: comma-separated proxy list for jobspy (avoids rate limits)
# PROXY_LIST=http://user:pass@host:port,http://user:pass@host2:port2
